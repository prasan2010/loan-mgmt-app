{
  "perspectives": [
    {
      "groups": [
        {
          "label": "controller",
          "patterns": [
            "src/main/java/com/loanapp/controller/**"
          ]
        },
        {
          "label": "service",
          "patterns": [
            "src/main/java/com/loanapp/service/**"
          ]
        },
        {
          "label": "repository",
          "patterns": [
            "src/main/java/com/loanapp/repository/**"
          ]
        },
        {
          "label": "model",
          "patterns": [
            "src/main/java/com/loanapp/model/**"
          ]
        },
        {
          "label": "dto",
          "patterns": [
            "src/main/java/com/loanapp/dto/**"
          ]
        },
        {
          "label": "mapper",
          "patterns": [
            "src/main/java/com/loanapp/mapper/**"
          ]
        },
        {
          "label": "config",
          "patterns": [
            "src/main/java/com/loanapp/config/**"
          ]
        }
      ],
      "constraints": [
        {
          "from": [
            "service"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "Service must never call back into controller — prevents reverse dependency cycle"
        },
        {
          "from": [
            "repository"
          ],
          "to": [
            "service"
          ],
          "relation": "deny",
          "description": "Repository must never call service — data layer must remain unaware of business logic"
        },
        {
          "from": [
            "repository"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "Repository must never call controller — no upward dependency from data layer"
        },
        {
          "from": [
            "model"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "Model (entities) must not depend on any higher layer — keeps domain objects pure"
        },
        {
          "from": [
            "model"
          ],
          "to": [
            "service"
          ],
          "relation": "deny",
          "description": "Model must not depend on service layer"
        },
        {
          "from": [
            "model"
          ],
          "to": [
            "repository"
          ],
          "relation": "deny",
          "description": "Model must not depend on repository to avoid circular JPA references"
        },
        {
          "from": [
            "dto"
          ],
          "to": [
            "service"
          ],
          "relation": "deny",
          "description": "DTOs are plain data carriers — must not depend on service or controller"
        },
        {
          "from": [
            "dto"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "DTOs must not depend on controller layer"
        },
        {
          "from": [
            "dto"
          ],
          "to": [
            "repository"
          ],
          "relation": "deny",
          "description": "DTOs must not depend on repository — no data access from transport objects"
        },
        {
          "from": [
            "mapper"
          ],
          "to": [
            "service"
          ],
          "relation": "deny",
          "description": "Mappers translate between model and dto only — must not call service logic"
        },
        {
          "from": [
            "mapper"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "Mappers must not depend on controller"
        },
        {
          "from": [
            "mapper"
          ],
          "to": [
            "repository"
          ],
          "relation": "deny",
          "description": "Mappers must not call repositories directly"
        },
        {
          "from": [
            "controller"
          ],
          "to": [
            "repository"
          ],
          "relation": "deny",
          "description": "Controller may only call service — direct repository access from controller bypasses business logic"
        },
        {
          "from": [
            "controller"
          ],
          "to": [
            "model"
          ],
          "relation": "deny",
          "description": "Controller must not import model entities directly — use DTOs for transport"
        },
        {
          "from": [
            "config"
          ],
          "to": [
            "controller"
          ],
          "relation": "deny",
          "description": "Config may wire service beans but must not depend on controller — avoids circular config"
        }
      ],
      "label": "java"
    }
  ]
}