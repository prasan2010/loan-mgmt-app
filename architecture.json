{
  "perspectives": [
    {
      "name": "java",
      "groups": [
        { "name": "controller", "pattern": "com/loanapp/controller/**" },
        { "name": "service",    "pattern": "com/loanapp/service/**"    }
      ],
      "constraints": [
        { "from": "controller", "to": "service", "type": "allowed" }
      ]
    }
  ]
}