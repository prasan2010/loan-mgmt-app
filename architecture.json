{
  "perspectives": [
    {
      "name": "java",
      "groups": [
        {
          "name": "controller",
          "pattern": "src/main/java/com/loanapp/controller/**"
        },
        {
          "name": "service",
          "pattern": "src/main/java/com/loanapp/service/**"
        }
      ],
      "constraints": [
        {
          "from": "service",
          "to": "controller",
          "relation": "deny"
        }
      ]
    }
  ]
}